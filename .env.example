# SGR Kernel / Platform
SGR_API_KEY=your-sgr-kernel-api-key-here
SGR_ENV=staging                              # staging | production

# LLM Providers
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-claude-key  # Optional
DEEPSEEK_API_KEY=your-deepseek-key           # For cost-efficient tasks (Qwen/DeepSeek)

# Vector Database
VECTOR_DB_URL=http://localhost:6333          # Qdrant / Weaviate / Chroma
VECTOR_DB_COLLECTION=staging_kb

# Object Storage (S3-compatible)
S3_ENDPOINT=https://storage.yandexcloud.net  # or AWS endpoint
S3_BUCKET=your-staging-bucket
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=ru-central1

# Database (PostgreSQL for production UIMemory)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sgr_db

# Compliance
COMPLIANCE_LEVEL=standard                    # standard | gdpr | rf_152fz
DATA_RETENTION_DAYS=90

# Telemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
